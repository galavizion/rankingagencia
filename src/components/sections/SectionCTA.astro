---
type CTA = { label: string; href: string };
const { settings } = Astro.props;

const theme = settings?.theme ?? "transparent";
const sectionId = settings?.id;

const {
  title,
  subtitle,
  primaryCta,
  secondaryCta,
} = Astro.props as {
  title?: string;
  subtitle?: string;
  primaryCta?: CTA | null;
  secondaryCta?: CTA | null;
};

// Sanity puede devolver null explícito, los defaults de desestructuración no cubren eso
const resolvedTitle = title ?? "¿Listo para hacerlo bien?";
const resolvedSubtitle = subtitle ?? "Dime qué estás construyendo y te digo cómo lo haría para que convierta.";
const resolvedPrimary = primaryCta ?? { label: "Contáctame", href: "/contacto" };
---

<section id={sectionId} class={`section section--${theme}`}>
  <div class="container">
    <div class="cta__card">
      <div class="cta__copy">
        <h2>{resolvedTitle}</h2>
        <p>{resolvedSubtitle}</p>
      </div>
      <div class="cta__actions">
        <a class="btn btn--primary" href={resolvedPrimary.href}>{resolvedPrimary.label}</a>
        {secondaryCta?.href ? (
          <a class="btn btn--ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
        ) : null}
      </div>
    </div>
  </div>
</section>

<style>
  .container{ max-width: 1100px; margin: 0 auto; padding: 0 20px; }
  .cta__card{
    border-radius: 18px;
    padding: 28px;
    border: 1px solid rgba(0,0,0,.12);
    display:flex;
    gap: 18px;
    align-items:center;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(230, 6, 6, 0.918), rgba(139, 11, 11, 0.938));
  }
  .cta__copy h2{ margin: 0 0 6px; color: #fff; }
  .cta__copy p{ margin: 0; opacity: .85; line-height: 1.6; max-width: 60ch; color: #fff; }
  .cta__actions{ display:flex; gap: 10px; flex-wrap: wrap; }
  .btn{ display:inline-flex; align-items:center; justify-content:center; padding: 10px 14px; border-radius: 12px; text-decoration:none; font-weight: 600; }
  .btn--primary{ background:#111; color:#fff; }
  .btn--ghost{ border:1px solid rgba(0,0,0,.18); color:#111; background:#fff; }
</style>