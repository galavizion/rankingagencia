---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanity, urlFor } from "../../lib/sanity";
import { toHTML } from "@portabletext/to-html";
import { SERVICE_BY_SLUG } from "../../lib/serviceQueries";

// ✅ Para hosting estático (HostGator /dist)
export const prerender = true;

type SlugRow = { slug: string };

export async function getStaticPaths() {
  const slugs = await sanity.fetch<SlugRow[]>(
    `*[_type=="service" && defined(slug.current)][]{"slug": slug.current}`
  );

  return (slugs ?? []).map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;

type Step = { title?: string; text?: string };
type Faq = { q?: string; a?: string };

type Service = {
  title?: string;
  slug?: string;
  kicker?: string;
  excerpt?: string;
  coverImage?: any;
  gallery?: any[];
  benefits?: string[];
  deliverables?: string[];
  processSteps?: Step[];
  faqs?: Faq[];
  content?: any[];
  seo?: {
    title?: string;
    description?: string;
    canonical?: string;
    noindex?: boolean;
    ogImage?: {
      asset?: {
        url?: string;
      };
    };
  };
};

const service = await sanity.fetch<Service>(SERVICE_BY_SLUG, { slug });

const SITE = "https://www.rankingagencia.com";
const canonical = `${SITE}/servicios/${slug}/`;

const pageTitle = service?.seo?.title || service?.title || "Servicio";
const pageDesc =
  service?.seo?.description || service?.excerpt || "Servicio de Ranking Agencia.";
// ✅ Imagen para schema (si hay coverImage)
const coverUrl = service?.coverImage
  ? urlFor(service.coverImage).width(1200).height(630).fit("crop").url()
  : `${SITE}/og.jpg`;

// ✅ Portable Text -> HTML
const html = service?.content
  ? toHTML(service.content, {
      components: {
        types: {
          image: ({ value }: any) => {
            const src = urlFor(value).width(1200).url();
            const alt = value?.alt || service?.title || "Imagen";
            return `<img src="${src}" alt="${alt}" loading="lazy" />`;
          },
        },
      },
    })
  : "";

// ✅ Schema: BreadcrumbList (estructura, no diseño)
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: "Servicios", item: `${SITE}/servicios/` },
    { "@type": "ListItem", position: 3, name: service?.title ?? "Servicio", item: canonical },
  ],
};

// ✅ Schema: Service (el bueno)
const serviceSchema: any = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonical}#service`,
  name: service?.title ?? "Servicio",
  description: pageDesc,
  url: canonical,
  inLanguage: "es-MX",
  provider: {
    "@type": "Organization",
    name: "Ranking Agencia",
    url: SITE,
  },
  ...(coverUrl ? { image: [coverUrl] } : {}),
  ...(Array.isArray(service?.deliverables) && service!.deliverables!.length
    ? {
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Entregables",
          itemListElement: service!.deliverables!.map((d) => ({
            "@type": "Offer",
            name: d,
          })),
        },
      }
    : {}),
};

// ✅ Schema: FAQPage (solo si hay FAQs)
const faqSchema =
  Array.isArray(service?.faqs) && service.faqs.length
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: service.faqs
          .filter((f) => f?.q && f?.a)
          .map((f) => ({
            "@type": "Question",
            name: f.q,
            acceptedAnswer: {
              "@type": "Answer",
              text: f.a,
            },
          })),
      }
    : null;

// ✅ Tu prop schema (manteniendo tu API de BaseLayout), pero ahora sí útil
const miSchema: any = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  name: `${pageTitle} | Ranking Agencia`,
  url: canonical,
  description: pageDesc,
  inLanguage: "es-MX",
  isPartOf: { "@type": "WebSite", "@id": `${SITE}/#website`, name: "Ranking Agencia", url: SITE },
  ...(coverUrl ? { primaryImageOfPage: { "@type": "ImageObject", url: coverUrl } } : {}),
};
---

<BaseLayout
  schema={miSchema}
  title={`${pageTitle} | Ranking Agencia`}
  description={pageDesc}
  canonical={canonical}
  seo={service?.seo}
>
  <!-- ✅ Schemas extra (no afectan estilo) -->
  <script type="application/ld+json" is:inline>
    {JSON.stringify(breadcrumbSchema)}
  </script>
  <script type="application/ld+json" is:inline>
    {JSON.stringify(serviceSchema)}
  </script>
  {faqSchema && (
    <script type="application/ld+json" is:inline>
      {JSON.stringify(faqSchema)}
    </script>
  )}

  <main class="container">
    {!service?.title ? (
      <p>Servicio no encontrado.</p>
    ) : (
      <>
        <header class="hero">
          <nav class="crumbs" aria-label="Breadcrumb">
            <a href="/">Inicio</a><span>/</span>
            <a href="/servicios/">Servicios</a><span>/</span>
            <span aria-current="page">{service.title}</span>
          </nav>

          {service.kicker && <div class="pill">{service.kicker}</div>}
          <h1>{service.title}</h1>
          {service.excerpt && <p class="desc">{service.excerpt}</p>}

          <div class="actions">
            <a class="btn btn--primary" href="/contacto/">Quiero una asesoría</a>
            <a
              class="btn btn--ghost"
              href={`https://wa.me/18133796971?text=${encodeURIComponent(`Quiero asesoría de: ${service.title}`)}`}
              target="_blank"
              rel="noreferrer noopener"
            >
              WhatsApp
            </a>
          </div>
        </header>

        {service.coverImage && (
          <figure class="cover">
            <img
              src={urlFor(service.coverImage).width(1400).height(780).fit("crop").url()}
              alt={service.title}
              loading="eager"
            />
          </figure>
        )}

        {Array.isArray(service.gallery) && service.gallery.length > 0 && (
          <section class="gallery" aria-label="Galería">
            {service.gallery.map((img) => (
              <img
                src={urlFor(img).width(900).height(600).fit("crop").url()}
                alt={img?.alt || service.title}
                loading="lazy"
              />
            ))}
          </section>
        )}

        {service.benefits?.length ? (
          <section class="box">
            <h2>Beneficios</h2>
            <ul>
              {service.benefits.map((b) => <li>{b}</li>)}
            </ul>
          </section>
        ) : null}

        {service.deliverables?.length ? (
          <section class="box">
            <h2>Entregables</h2>
            <ul>
              {service.deliverables.map((d) => <li>{d}</li>)}
            </ul>
          </section>
        ) : null}

        {service.processSteps?.length ? (
          <section class="box">
            <h2>Proceso</h2>
            <ol class="steps">
              {service.processSteps.map((st, i) => (
                <li class="step">
                  <strong>{i + 1}. {st.title}</strong>
                  {st.text && <p>{st.text}</p>}
                </li>
              ))}
            </ol>
          </section>
        ) : null}

        {service.faqs?.length ? (
          <section class="box">
            <h2>Preguntas frecuentes</h2>
            <div class="faq">
              {service.faqs.map((f) => (
                <details>
                  <summary>{f.q}</summary>
                  <p>{f.a}</p>
                </details>
              ))}
            </div>
          </section>
        ) : null}

        {html ? <section class="content" set:html={html} /> : null}
      </>
    )}
  </main>
</BaseLayout>

<style>
  .container{max-width:980px;margin:0 auto;padding:2.25rem 1rem;}
  .crumbs{display:flex;gap:10px;flex-wrap:wrap;font-size:13px;opacity:.85;margin-bottom:14px}
  .crumbs span{opacity:.6}
  .hero{background:rgba(255,255,255,.92);border:1px solid rgba(0,0,0,.10);border-radius:18px;padding:22px;box-shadow:0 8px 30px rgba(0,0,0,.06)}
  .pill{display:inline-flex;padding:6px 10px;border-radius:999px;font-weight:900;font-size:12px;background:rgba(66,117,255,.12)}
  h1{margin:14px 0 10px;font-size:clamp(30px,3.2vw,46px);line-height:1.08}
  .desc{margin:0;opacity:.9;line-height:1.6;max-width:70ch}
  .actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}
  .btn{display:inline-flex;align-items:center;justify-content:center;padding:12px 16px;border-radius:14px;font-weight:900;text-decoration:none}
  .btn--primary{background:var(--thm-primary);color:#fff}
  .btn--ghost{background:transparent;border:1px solid rgba(0,0,0,.14);color:inherit}
  .cover{margin:16px 0 0}
  .cover img{width:100%;height:auto;display:block;border-radius:18px;border:1px solid rgba(0,0,0,.10);box-shadow:0 8px 30px rgba(0,0,0,.06)}
  .gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin:16px 0 0}
  .gallery img{width:100%;height:auto;border-radius:16px;border:1px solid rgba(0,0,0,.10)}
  .box{
    margin-top:16px;
    background: rgba(255,255,255,.92);
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 18px;
    padding: 18px;
    box-shadow: 0 8px 30px rgba(0,0,0,.06);
  }
  .box h2{ margin:0 0 10px; font-size:22px; }
  .box ul{ margin:0; padding-left:18px; }
  .box li{ margin:0 0 8px; line-height:1.65; }
  .steps{ margin:0; padding-left:18px; display:grid; gap:10px; }
  .step p{ margin:6px 0 0; opacity:.9; line-height:1.6; }
  .faq details{ border:1px solid rgba(0,0,0,.10); border-radius:14px; padding:10px 12px; margin:0 0 10px; background: rgba(0,0,0,.02); }
  .faq summary{ cursor:pointer; font-weight:900; }
  .faq p{ margin:8px 0 0; line-height:1.65; opacity:.9; }
  .content{margin-top:16px;background:rgba(255,255,255,.92);border:1px solid rgba(0,0,0,.10);border-radius:18px;padding:26px;box-shadow:0 8px 30px rgba(0,0,0,.06)}
</style>