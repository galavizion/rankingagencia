---
import Builder from "../components/builder/Builder.astro";
import { sanityFetch } from "../lib/sanity/client";
import { allPageSlugsQuery, pageBySlugQuery } from "../lib/sanity/queries";

export const prerender = true;
const miSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Ranking Agencia",
  url: "https://www.rankingagencia.com/",
};
export async function getStaticPaths() {
  const all = await sanityFetch<{ slug: string; pageType: string }[]>({
    query: allPageSlugsQuery,
  });

  // home normalmente es index.astro, así que la excluimos aquí
  const filtered = all.filter(p => p.pageType !== "home");

  return filtered.map(p => ({
    params: { slug: p.slug.split("/") },
    props: { pageType: p.pageType },
  }));
}

const slug = (Astro.params.slug ?? []).join("/");
const page = await sanityFetch<any>({ query: pageBySlugQuery, params: { slug } });

if (!page) throw new Error(`Page not found: ${slug}`);
---

<html lang="es">
  <head>
    <title>{page.title}</title>
  </head>
  <body>
    <Builder sections={page.sections} />
  </body>
</html>